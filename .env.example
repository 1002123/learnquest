# Server
PORT=3001
NODE_ENV=development

# JWT Secret — change this to a long random string in production
JWT_SECRET=learnquest_super_secret_key_change_in_production

# JWT Expiry
JWT_EXPIRES_IN=7d

# Groq API Key — get free key at console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Groq Model (optional — default is llama-3.3-70b-versatile)
# Options: llama-3.3-70b-versatile | llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile

# CORS — your frontend origin
ALLOWED_ORIGINS=http://localhost:3001

# Database path
DB_PATH=./learnquest.db
